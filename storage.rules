rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /event_images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /user_uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
